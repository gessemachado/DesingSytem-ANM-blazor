@page "/barragem/{Id:int}/caracteristicas-tecnicas"
@rendermode InteractiveServer
@using SIGBM.Models
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Características Técnicas — SIGBM</PageTitle>

<div class="page-wrap">
    <SigbmSidebar NumeroCadastro="@Id" />

    <main class="page-main">

        <div class="page-heading-wrap">
            <MudBreadcrumbs Items="_crumbs" />
            <MudText Typo="Typo.h6" Class="page-heading-id">#@Id — Barragem A</MudText>
            <MudText Typo="Typo.caption" Class="page-heading-company">Empresa A · 00.000.000/0000-00</MudText>
        </div>

        <MudPaper Elevation="1" Style="border-radius:8px;overflow:hidden;" Class="mb-4">
            <MudTabs Elevation="0" Rounded="false" ApplyEffectsToContainer="true">

                <MudTabPanel Text="Barramento Principal">
                    <div class="pa-5">
                        <FormCaracteristicas Modelo="@BarramentoPrincipal" />
                    </div>
                </MudTabPanel>

                <MudTabPanel Text="Dique 01">
                    <div class="pa-5">
                        <FormCaracteristicas Modelo="@Dique01" />
                    </div>
                </MudTabPanel>

            </MudTabs>
        </MudPaper>

        <div class="d-flex justify-end gap-2">
            <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack"
                       @onclick='() => Nav.NavigateTo($"/barragem/{Id}/dados-iniciais")'>
                Voltar
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Save" @onclick="Salvar">
                Salvar
            </MudButton>
        </div>

    </main>
</div>

@code {
    [Parameter] public int Id { get; set; } = 9999;

    private List<BreadcrumbItem> _crumbs =
    [
        new("Início", href: "/", icon: Icons.Material.Filled.Home),
        new("Minhas Barragens", href: "/barragens"),
        new("Barragem #9999", href: null, disabled: false),
        new("Características Técnicas", href: null, disabled: true),
    ];

    private CaractModel BarramentoPrincipal = new()
    {
        AlturaMaximaProjeto      = "50,00",
        AlturaMaximaAtual        = "45,00",
        ComprimentoCristaProjeto = "400,00",
        ComprimentoCristaAtual   = "320,00",
        TipoBarragem             = "alteamento",
        FaseVida                 = "operacao",
        MaterialConstrucao       = "terra_homogenea",
        TipoFundacao             = "rocha_competente",
        MetodoConstrutivo        = "jusante",
        DrenagemInterna          = "adequada",
        DrenagemSuperficial      = "adequada",
        InclinacaoTalude         = "3:1_menor",
        Instrumentacao           = "adequada",
        VazaoProjeto             = "tr10000",
        MinerioReservatorio      = "Minério de Ferro",
        AreaReservatorio         = "100.000,00",
        UsoPrincipalRejeitos     = true,
        MassaRejeito             = true,
    };

    private CaractModel Dique01 = new();

    private void Salvar() => Snackbar.Add("Características técnicas salvas!", Severity.Success);
}
