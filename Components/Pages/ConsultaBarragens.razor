@page "/barragens"
@rendermode InteractiveServer
@inject NavigationManager Nav

<PageTitle>Minhas Barragens — SIGBM</PageTitle>

<div style="padding:24px;max-width:1280px;margin:0 auto;">

    <MudBreadcrumbs Items="_crumbs" />

    <div class="d-flex justify-space-between align-center mt-2 mb-4">
        <div>
            <MudText Typo="Typo.h5" Style="font-weight:700;">Minhas Barragens</MudText>
            <MudText Typo="Typo.caption" Style="color:#636366;">Gerencie e acompanhe todas as estruturas cadastradas</MudText>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   Href="/barragem/nova" Size="Size.Medium">
            Nova barragem
        </MudButton>
    </div>

    <!-- KPI cards -->
    <div class="kpi-row">
        <div class="kpi-card kpi-card--blue">
            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Style="width:48px;height:48px;">
                <MudIcon Icon="@Icons.Material.Filled.Water" />
            </MudAvatar>
            <div>
                <MudText Typo="Typo.h4" Style="font-weight:700;color:#1351B4;line-height:1;">@Barragens.Count</MudText>
                <MudText Typo="Typo.body2" Style="color:#636366;font-size:13px;">Total de Barragens</MudText>
            </div>
        </div>
        <div class="kpi-card kpi-card--orange">
            <MudAvatar Style="width:48px;height:48px;background:#FEF3C7;">
                <MudIcon Icon="@Icons.Material.Filled.HourglassEmpty" Style="color:#D97706;" />
            </MudAvatar>
            <div>
                <MudText Typo="Typo.h4" Style="font-weight:700;color:#D97706;line-height:1;">@Barragens.Count(b => b.Status == "andamento")</MudText>
                <MudText Typo="Typo.body2" Style="color:#636366;font-size:13px;">Em Andamento</MudText>
            </div>
        </div>
        <div class="kpi-card kpi-card--red">
            <MudAvatar Style="width:48px;height:48px;background:#FEE2E2;">
                <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Style="color:#DC2626;" />
            </MudAvatar>
            <div>
                <MudText Typo="Typo.h4" Style="font-weight:700;color:#DC2626;line-height:1;">@Barragens.Count(b => b.Status == "pendente")</MudText>
                <MudText Typo="Typo.body2" Style="color:#636366;font-size:13px;">Pendentes</MudText>
            </div>
        </div>
        <div class="kpi-card kpi-card--green">
            <MudAvatar Style="width:48px;height:48px;background:#DCFCE7;">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Style="color:#16A34A;" />
            </MudAvatar>
            <div>
                <MudText Typo="Typo.h4" Style="font-weight:700;color:#16A34A;line-height:1;">@Barragens.Count(b => b.Status == "concluido")</MudText>
                <MudText Typo="Typo.body2" Style="color:#636366;font-size:13px;">Concluídos</MudText>
            </div>
        </div>
    </div>

    <!-- Filtros -->
    <MudPaper Elevation="1" Class="pa-4 mb-3" Style="border-radius:8px;">
        <MudGrid Spacing="2">
            <MudItem xs="12" md="5">
                <MudTextField T="string" @bind-Value="FiltroTexto"
                              Label="Busca rápida"
                              Placeholder="Nome da barragem ou empresa…"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Clearable="true" />
            </MudItem>
            <MudItem xs="6" md="3">
                <MudSelect T="string" @bind-Value="FiltroStatus" Label="Status"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           AdornmentIcon="@Icons.Material.Filled.FilterList"
                           Adornment="Adornment.Start">
                    <MudSelectItem T="string" Value="@("")">Todos</MudSelectItem>
                    <MudSelectItem T="string" Value="@("andamento")">Em andamento</MudSelectItem>
                    <MudSelectItem T="string" Value="@("concluido")">Concluído</MudSelectItem>
                    <MudSelectItem T="string" Value="@("pendente")">Pendente</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="6" md="2">
                <MudSelect T="string" @bind-Value="FiltroRisco" Label="Risco"
                           Variant="Variant.Outlined" Margin="Margin.Dense">
                    <MudSelectItem T="string" Value="@("")">Todos</MudSelectItem>
                    <MudSelectItem T="string" Value="@("alto")">Alto</MudSelectItem>
                    <MudSelectItem T="string" Value="@("medio")">Médio</MudSelectItem>
                    <MudSelectItem T="string" Value="@("baixo")">Baixo</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2" Class="d-flex gap-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Search" FullWidth="true">
                    Filtrar
                </MudButton>
                <MudTooltip Text="Limpar filtros">
                    <MudIconButton Icon="@Icons.Material.Filled.ClearAll"
                                   Variant="Variant.Outlined"
                                   @onclick="LimparFiltros" />
                </MudTooltip>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <!-- Tabela -->
    <MudTable T="BarragemItem" Items="@BarragensFiltradas" Hover="true"
              RowsPerPage="@ItensPorPagina" Elevation="1"
              Style="border-radius:8px;overflow:hidden;"
              SortLabel="Ordenar por">
        <ToolBarContent>
            <MudText Typo="Typo.subtitle2" Style="font-weight:600;">
                @BarragensFiltradas.Count() barragem(ns) encontrada(s)
            </MudText>
            <MudSpacer />
            <MudTooltip Text="Exportar lista">
                <MudIconButton Icon="@Icons.Material.Filled.FileDownload" Variant="Variant.Text" Size="Size.Small" />
            </MudTooltip>
        </ToolBarContent>
        <HeaderContent>
            <MudTh Style="width:56px;"></MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<BarragemItem, object>(x => x.Id)">
                    Nº Cadastro
                </MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<BarragemItem, object>(x => x.Nome)">
                    Nome da Barragem
                </MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<BarragemItem, object>(x => x.Empresa)">
                    Empresa
                </MudTableSortLabel>
            </MudTh>
            <MudTh>UF</MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<BarragemItem, object>(x => x.Risco)">
                    Risco
                </MudTableSortLabel>
            </MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<BarragemItem, object>(x => x.Status)">
                    Status
                </MudTableSortLabel>
            </MudTh>
            <MudTh Style="width:48px;"></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudAvatar Size="Size.Small" Style="@($"background:{AvatarColor(context.Empresa)};color:#fff;font-size:13px;font-weight:700;")">
                    @context.Empresa[0]
                </MudAvatar>
            </MudTd>
            <MudTd DataLabel="Nº Cadastro">
                <MudLink Href="@($"/barragem/{context.Id}/dados-iniciais")"
                         Style="font-weight:600;color:#1351B4;">#@context.Id</MudLink>
            </MudTd>
            <MudTd DataLabel="Nome">
                <MudText Style="font-weight:500;">@context.Nome</MudText>
            </MudTd>
            <MudTd DataLabel="Empresa">
                <MudText Typo="Typo.body2" Style="color:#636366;">@context.Empresa</MudText>
            </MudTd>
            <MudTd DataLabel="UF">
                <MudChip T="string" Size="Size.Small" Style="background:#F0F0F5;color:#1B1B1B;font-weight:600;">
                    @context.UF
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Risco">
                <MudChip T="string" Size="Size.Small" Class="@($"chip-{context.Risco}")">
                    @context.RiscoLabel
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Size="Size.Small" Class="@($"chip-{context.Status}")">
                    @context.StatusLabel
                </MudChip>
            </MudTd>
            <MudTd>
                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small"
                         Dense="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                    <MudMenuItem Icon="@Icons.Material.Filled.Edit"
                                 OnClick="@(() => IrParaBarragem(context.Id))">
                        Editar
                    </MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.Visibility">
                        Visualizar
                    </MudMenuItem>
                    <MudDivider />
                    <MudMenuItem Icon="@Icons.Material.Filled.Archive" IconColor="Color.Default">
                        Arquivar
                    </MudMenuItem>
                </MudMenu>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <div class="empty-state">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" />
                <MudText Typo="Typo.subtitle2">Nenhuma barragem encontrada</MudText>
                <MudText Typo="Typo.caption">Tente ajustar os filtros de busca</MudText>
            </div>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[]{10,25,50}" />
        </PagerContent>
    </MudTable>

</div>

@code {
    private string FiltroTexto = "";
    private string FiltroStatus = "";
    private string FiltroRisco = "";
    private int ItensPorPagina = 10;

    private List<BreadcrumbItem> _crumbs =
    [
        new("Início", href: "/", icon: Icons.Material.Filled.Home),
        new("Gerenciar", href: null, disabled: true),
        new("Minhas Barragens", href: null, disabled: true),
    ];

    private List<BarragemItem> Barragens =
    [
        new(9999, "Barragem A", "Empresa A", "MG", "alto",  "andamento"),
        new(9998, "Barragem B", "Empresa B", "PA", "medio", "concluido"),
        new(9997, "Barragem C", "Empresa A", "GO", "baixo", "pendente"),
        new(9996, "Barragem D", "Empresa C", "MG", "alto",  "andamento"),
    ];

    private IEnumerable<BarragemItem> BarragensFiltradas =>
        Barragens.Where(b =>
            (string.IsNullOrEmpty(FiltroTexto) ||
             b.Nome.Contains(FiltroTexto, StringComparison.OrdinalIgnoreCase) ||
             b.Empresa.Contains(FiltroTexto, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(FiltroStatus) || b.Status == FiltroStatus) &&
            (string.IsNullOrEmpty(FiltroRisco)  || b.Risco  == FiltroRisco));

    private void LimparFiltros() { FiltroTexto = ""; FiltroStatus = ""; FiltroRisco = ""; }
    private void IrParaBarragem(int id) => Nav.NavigateTo($"/barragem/{id}/dados-iniciais");

    private static string AvatarColor(string empresa) => empresa switch
    {
        "Empresa A" => "#1351B4",
        "Empresa B" => "#168821",
        "Empresa C" => "#9333EA",
        _ => "#636366"
    };

    private record BarragemItem(int Id, string Nome, string Empresa, string UF, string Risco, string Status)
    {
        public string RiscoLabel  => Risco  switch { "alto"  => "Alto",        "medio"  => "Médio",      "baixo"     => "Baixo",     _ => Risco };
        public string StatusLabel => Status switch { "andamento" => "Em andamento", "concluido" => "Concluído", "pendente" => "Pendente", _ => Status };
    }
}
