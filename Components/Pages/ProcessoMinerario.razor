@page "/barragem/{Id:int}/processo-minerario"
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>Processo Minerário — SIGBM</PageTitle>

@if (MostrarAlerta)
{
    <MudAlert Severity="Severity.Warning" Class="sigbm-alert" Dense="true"
              ShowCloseIcon="true" CloseIconClicked="@(() => MostrarAlerta = false)">
        <strong>Atenção.</strong> Faltam 30 dias para finalizar o cadastro desta estrutura.
    </MudAlert>
}

<div class="page-wrap">
    <SigbmSidebar NumeroCadastro="@Id" />

    <main class="page-main">

        <div class="page-heading-wrap">
            <MudBreadcrumbs Items="_crumbs" />
            <MudText Typo="Typo.h6" Class="page-heading-id">#@Id — Barragem A</MudText>
            <MudText Typo="Typo.caption" Class="page-heading-company">Empresa A · 00.000.000/0000-00</MudText>
        </div>

        <!-- Vincular processo -->
        <MudPaper Elevation="1" Class="pa-5 mb-4" Style="border-radius:8px;">
            <div class="section-header mb-1">
                <MudIcon Icon="@Icons.Material.Filled.Link" />
                <span>Vincular Processo Minerário</span>
            </div>
            <span class="section-sub">Informe o número do processo ANM (SCUP) para vincular à estrutura</span>
            <div class="add-row">
                <MudTextField @bind-Value="NovoProcesso"
                              Label="Número do Processo"
                              Placeholder="Ex: 800.000/2020"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Style="flex:1;"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Outlined.Tag" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Link"
                           @onclick="VincularProcesso"
                           Style="margin-bottom:2px;"
                           Disabled="@string.IsNullOrWhiteSpace(NovoProcesso)">
                    Vincular
                </MudButton>
            </div>
        </MudPaper>

        <!-- Tabela de processos -->
        <MudPaper Elevation="1" Style="border-radius:8px;overflow:hidden;" Class="mb-4">
            <MudTable T="ProcessoItem" Items="@Processos" Hover="true" Elevation="0" Dense="false">
                <ToolBarContent>
                    <div class="section-header" style="margin-bottom:0;">
                        <MudIcon Icon="@Icons.Material.Filled.AccountTree" Style="font-size:18px !important;" />
                        <span style="font-size:14px;">Processos vinculados</span>
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Style="height:20px;">
                            @Processos.Count
                        </MudChip>
                    </div>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>Processo</MudTh>
                    <MudTh>Substância</MudTh>
                    <MudTh>Fase</MudTh>
                    <MudTh>Área (ha)</MudTh>
                    <MudTh>UF</MudTh>
                    <MudTh>Município</MudTh>
                    <MudTh Style="width:48px;"></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudLink Href="#" Style="font-weight:600;color:#1351B4;">@context.Numero</MudLink>
                    </MudTd>
                    <MudTd>
                        <div style="display:flex;align-items:center;gap:6px;">
                            <MudAvatar Size="Size.Small"
                                       Style="width:24px;height:24px;font-size:10px;background:#EEF4FF;color:#1351B4;font-weight:700;">
                                @context.Substancia[0]
                            </MudAvatar>
                            @context.Substancia
                        </div>
                    </MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Class="@FaseClass(context.Fase)">
                            @context.Fase
                        </MudChip>
                    </MudTd>
                    <MudTd>@context.Area</MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Style="background:#F0F0F5;color:#1B1B1B;font-weight:600;">
                            @context.UF
                        </MudChip>
                    </MudTd>
                    <MudTd>@context.Municipio</MudTd>
                    <MudTd>
                        <MudTooltip Text="Desvincular processo">
                            <MudIconButton Icon="@Icons.Material.Filled.LinkOff" Size="Size.Small"
                                           Color="Color.Error"
                                           OnClick="@(() => DesvinculaProcesso(context))" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <div class="empty-state">
                        <MudIcon Icon="@Icons.Material.Filled.LinkOff" />
                        <MudText Typo="Typo.subtitle2">Nenhum processo vinculado</MudText>
                        <MudText Typo="Typo.caption">Use o campo acima para vincular um processo ANM</MudText>
                    </div>
                </NoRecordsContent>
            </MudTable>
        </MudPaper>

        <!-- Ações -->
        <div class="d-flex justify-end gap-2">
            <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack"
                       @onclick='() => Nav.NavigateTo($"/barragem/{Id}/dados-iniciais")'>
                Voltar
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Save" @onclick="Salvar">
                Salvar
            </MudButton>
        </div>

    </main>
</div>

@code {
    [Parameter] public int Id { get; set; } = 9999;

    private bool MostrarAlerta = true;
    private string NovoProcesso = "";

    private List<BreadcrumbItem> _crumbs =
    [
        new("Início", href: "/", icon: Icons.Material.Filled.Home),
        new("Minhas Barragens", href: "/barragens"),
        new("Barragem #9999", href: null, disabled: false),
        new("Processo Minerário", href: null, disabled: true),
    ];

    private List<ProcessoItem> Processos =
    [
        new("800.001/2018", "Ferro", "Concessão de Lavra",      "1.234,56", "MG", "Congonhas"),
        new("800.002/2020", "Ouro",  "Autorização de Pesquisa", "345,00",   "MG", "Mariana"),
    ];

    private void VincularProcesso()
    {
        if (!string.IsNullOrWhiteSpace(NovoProcesso))
        {
            Processos.Add(new(NovoProcesso, "—", "Em análise", "0,00", "—", "—"));
            NovoProcesso = "";
            Snackbar.Add("Processo vinculado com sucesso!", Severity.Success);
        }
    }

    private async Task DesvinculaProcesso(ProcessoItem p)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Deseja desvincular o processo {p.Numero}?"))
        {
            Processos.Remove(p);
            Snackbar.Add($"Processo {p.Numero} desvinculado.", Severity.Info);
        }
    }

    private void Salvar() => Snackbar.Add("Processos salvos com sucesso!", Severity.Success);

    private static string FaseClass(string fase) => fase switch
    {
        "Concessão de Lavra"     => "chip-concluido",
        "Autorização de Pesquisa"=> "chip-andamento",
        "Em análise"             => "chip-pendente",
        _                        => "chip-andamento"
    };

    private record ProcessoItem(string Numero, string Substancia, string Fase, string Area, string UF, string Municipio);
}
